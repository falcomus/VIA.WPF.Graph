<Window x:Class="VIA.WPF.Graph.Demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VIA.WPF.Graph – P0-002 Graphviz-Verifikation"
        Width="980"
        Height="720"
        MinWidth="720"
        MinHeight="460">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="16" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <DockPanel Grid.Row="0">
      <StackPanel DockPanel.Dock="Left">
        <TextBlock FontSize="22"
                   FontWeight="SemiBold"
                   Text="P0-002 – Rubjerg.Graphviz 3.0.5" />
        <TextBlock Margin="0,8,0,0"
                   TextWrapping="Wrap"
                   Text="Technischer Test: Paket, native Runtime, TB-/LR-Layout, Cluster und Kanten-Geometrie." />
      </StackPanel>
      <Button DockPanel.Dock="Right"
              MinWidth="180"
              Padding="14,7"
              Command="{Binding RunVerificationCommand}"
              Content="Prüfung erneut ausführen" />
    </DockPanel>

    <TextBox Grid.Row="2"
             IsReadOnly="True"
             AcceptsReturn="True"
             Text="{Binding ResultText, Mode=OneWay}"
             TextWrapping="NoWrap"
             VerticalScrollBarVisibility="Auto"
             HorizontalScrollBarVisibility="Auto"
             FontFamily="Consolas"
             FontSize="14"
             Padding="12" />
  </Grid>
</Window>
