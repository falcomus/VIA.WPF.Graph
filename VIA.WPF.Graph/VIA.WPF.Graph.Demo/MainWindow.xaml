<Window x:Class="VIA.WPF.Graph.Demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:graphControls="clr-namespace:VIA.WPF.Graph.Wpf.Controls;assembly=VIA.WPF.Graph.Wpf"
        Title="VIA.WPF.Graph – Product Demo"
        Width="1500"
        Height="920"
        WindowState="Maximized"
        MinWidth="1200"
        MinHeight="760"
        Background="#EEF3F8">
  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Resources/ProductDemoResources.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Grid Background="{StaticResource PageBackgroundBrush}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Margin="18,18,18,10"
            Padding="20,14"
            Style="{StaticResource CardBorderStyle}">
      <DockPanel LastChildFill="False">
        <StackPanel DockPanel.Dock="Left">
          <TextBlock FontSize="24"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource TitleTextBrush}"
                     Text="Product App Navigation Demo" />
          <TextBlock Margin="0,4,0,0"
                     MaxWidth="720"
                     Style="{StaticResource MutedTextStyle}"
                     Text="Tree, graph and inspector use neutral graph data. Later editing can define navigation, popups and interaction areas through host requests." />
        </StackPanel>

        <StackPanel DockPanel.Dock="Right"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
          <Button Style="{StaticResource ToolbarButtonStyle}"
                  Command="{Binding ShowGraphOverviewCommand}"
                  Content="Branch" />
          <Button Style="{StaticResource PrimaryToolbarButtonStyle}"
                  Command="{Binding ShowFocusCommand}"
                  Content="Focus" />
          <Button Style="{StaticResource ToolbarButtonStyle}"
                  Command="{Binding ShowAreaOverviewCommand}"
                  Content="Areas" />
          <Button Style="{StaticResource ToolbarButtonStyle}"
                  Command="{Binding FitToGraphCommand}"
                  Content="Fit" />
          <Button Style="{StaticResource ToolbarButtonStyle}"
                  Command="{Binding SetActualSizeCommand}"
                  Content="100 %" />
          <Button Style="{StaticResource ToolbarButtonStyle}"
                  Command="{Binding CenterGraphCommand}"
                  Content="Center selected" />
          <Border Margin="8,0,0,0"
                  Padding="12,7"
                  Background="#FFEAF2FA"
                  BorderBrush="#FFD2E0EC"
                  BorderThickness="1"
                  CornerRadius="9">
            <TextBlock FontWeight="SemiBold"
                       Foreground="#FF315B7E"
                       Text="{Binding CountsText}" />
          </Border>
        </StackPanel>
      </DockPanel>
    </Border>

    <Grid Grid.Row="1"
          Margin="18,0,18,10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="430" />
        <ColumnDefinition Width="1" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="1" />
        <ColumnDefinition Width="330" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0"
              Background="{StaticResource CardBackgroundBrush}"
              BorderBrush="{StaticResource CardBorderBrush}"
              BorderThickness="1,1,0,1"
              SnapsToDevicePixels="True">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <Border Grid.Row="0"
                  Padding="20,17,20,13"
                  Style="{StaticResource WorkspaceHeaderBorderStyle}">
            <StackPanel>
              <TextBlock FontSize="17"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource TitleTextBrush}"
                         Text="Navigation tree" />
              <TextBlock Margin="0,5,0,0"
                         Style="{StaticResource MutedTextStyle}"
                         Text="Expandable app areas with concrete navigation paths and references." />
            </StackPanel>
          </Border>

          <TreeView x:Name="NavigationTree"
                    Grid.Row="1"
                    Margin="20,10,6,14"
                    ItemContainerStyle="{StaticResource ProductNavigationTreeItemContainerStyle}"
                    ItemsSource="{Binding NavigationGroups}"
                    SelectedItemChanged="OnNavigationTreeSelectedItemChanged"
                    Style="{StaticResource ProductNavigationTreeViewStyle}" />
        </Grid>
      </Border>

      <Border Grid.Column="1"
              Background="{StaticResource CardBorderBrush}" />

      <Border Grid.Column="2"
              Padding="18,16"
              Background="{StaticResource CardBackgroundBrush}"
              BorderBrush="{StaticResource CardBorderBrush}"
              BorderThickness="0,1,0,1"
              SnapsToDevicePixels="True">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <DockPanel Grid.Row="0"
                     Margin="0,0,0,10"
                     LastChildFill="False">
            <StackPanel DockPanel.Dock="Left"
                        MinWidth="360">
              <TextBlock FontSize="16"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource TitleTextBrush}"
                         Text="Graph area" />
              <TextBlock Margin="0,4,0,0"
                         Style="{StaticResource MutedTextStyle}"
                         Text="{Binding ModeText}" />
            </StackPanel>

            <Border DockPanel.Dock="Right"
                    Padding="10,6"
                    Background="#FFF4F8FC"
                    BorderBrush="#FFD4E0EB"
                    BorderThickness="1"
                    CornerRadius="8">
              <TextBlock FontWeight="SemiBold"
                         Foreground="{StaticResource AccentBrush}"
                         Text="{Binding CurrentScopeText}" />
            </Border>
          </DockPanel>

          <Border x:Name="GraphCanvasHost"
                  Grid.Row="1"
                  ClipToBounds="True"
                  Background="#FFF4F8FC"
                  BorderBrush="#FFD4E0EB"
                  BorderThickness="1"
                  CornerRadius="8">
            <graphControls:GraphCanvas x:Name="GraphCanvasView"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch"
                                       Document="{Binding CurrentDocument}"
                                       LayoutResult="{Binding CurrentLayout}"
                                       ActiveViewMode="{Binding ActiveViewMode, Mode=TwoWay}"
                                       VisualDensity="{Binding VisualDensity, Mode=TwoWay}"
                                       SelectedNodeIds="{Binding SelectedNodeIds, Mode=TwoWay}"
                                       SelectedLinkIds="{Binding SelectedLinkIds, Mode=TwoWay}"
                                       SelectedGroupIds="{Binding SelectedGroupIds, Mode=TwoWay}"
                                       FocusedNodeId="{Binding FocusedNodeId, Mode=TwoWay}"
                                       FocusedGroupId="{Binding FocusedGroupId, Mode=TwoWay}"
                                       Zoom="{Binding Zoom, Mode=TwoWay}"
                                       PanX="{Binding PanX, Mode=TwoWay}"
                                       PanY="{Binding PanY, Mode=TwoWay}"
                                       GraphRequestCommand="{Binding GraphRequestCommand}" />
          </Border>

          <Border Grid.Row="2"
                  Margin="0,10,0,0"
                  Padding="12,9"
                  Style="{StaticResource InsetPanelBorderStyle}">
            <TextBlock Style="{StaticResource MutedTextStyle}"
                       Text="Mouse wheel zooms. Right or middle mouse button pans. Tree selection centers the related graph node." />
          </Border>
        </Grid>
      </Border>

      <Border Grid.Column="3"
              Background="{StaticResource CardBorderBrush}" />

      <Border Grid.Column="4"
              Padding="18,16"
              Background="{StaticResource CardBackgroundBrush}"
              BorderBrush="{StaticResource CardBorderBrush}"
              BorderThickness="0,1,1,1"
              SnapsToDevicePixels="True">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
          <StackPanel>
            <TextBlock FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TitleTextBrush}"
                       Text="Inspector" />
            <TextBlock Margin="0,4,0,12"
                       Style="{StaticResource MutedTextStyle}"
                       Text="Selection details and later editing options." />

            <Border Padding="14"
                    Style="{StaticResource InsetPanelBorderStyle}">
              <StackPanel>
                <TextBlock FontSize="19"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TitleTextBrush}"
                           Text="{Binding SelectedScreenTitle}" />
                <TextBlock Margin="0,6,0,0"
                           Style="{StaticResource MutedTextStyle}"
                           Text="{Binding SelectedScreenSubtitle}" />
              </StackPanel>
            </Border>

            <Border Margin="0,12,0,0"
                    Padding="14"
                    Style="{StaticResource InsetPanelBorderStyle}">
              <StackPanel>
                <TextBlock FontWeight="SemiBold"
                           Foreground="{StaticResource TitleTextBrush}"
                           Text="Classification" />
                <TextBlock Margin="0,8,0,0"
                           Style="{StaticResource MutedTextStyle}"
                           Text="{Binding SelectedScreenKindText}" />
                <TextBlock Margin="0,5,0,0"
                           Style="{StaticResource MutedTextStyle}"
                           Text="{Binding SelectedScreenAreaText}" />
              </StackPanel>
            </Border>

            <Border Margin="0,12,0,0"
                    Padding="14"
                    Style="{StaticResource InsetPanelBorderStyle}">
              <StackPanel>
                <TextBlock FontWeight="SemiBold"
                           Foreground="{StaticResource TitleTextBrush}"
                           Text="Navigation path" />
                <TextBlock Margin="0,8,0,0"
                           Style="{StaticResource MutedTextStyle}"
                           Text="{Binding SelectedPathText}" />
              </StackPanel>
            </Border>

            <Border Margin="0,12,0,0"
                    Padding="14"
                    Style="{StaticResource InsetPanelBorderStyle}">
              <StackPanel>
                <TextBlock FontWeight="SemiBold"
                           Foreground="{StaticResource TitleTextBrush}"
                           Text="Incoming" />
                <TextBlock Margin="0,8,0,0"
                           Style="{StaticResource MutedTextStyle}"
                           Text="{Binding SelectedIncomingLinksText}" />
              </StackPanel>
            </Border>

            <Border Margin="0,12,0,0"
                    Padding="14"
                    Style="{StaticResource InsetPanelBorderStyle}">
              <StackPanel>
                <TextBlock FontWeight="SemiBold"
                           Foreground="{StaticResource TitleTextBrush}"
                           Text="Outgoing" />
                <TextBlock Margin="0,8,0,0"
                           Style="{StaticResource MutedTextStyle}"
                           Text="{Binding SelectedOutgoingLinksText}" />
              </StackPanel>
            </Border>

            <Border Margin="0,12,0,0"
                    Padding="14"
                    Style="{StaticResource InsetPanelBorderStyle}">
              <StackPanel>
                <TextBlock FontWeight="SemiBold"
                           Foreground="{StaticResource TitleTextBrush}"
                           Text="Future editing" />
                <TextBlock Margin="0,8,0,0"
                           Style="{StaticResource MutedTextStyle}"
                           Text="Navigation, popups and interaction regions will later be edited through neutral graph requests. The library still does not know UserFlow domain types." />
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>

    <Border Grid.Row="2"
            Margin="18,0,18,18"
            Padding="14,9"
            Background="#FFFFFFFF"
            BorderBrush="#FFD8E4EF"
            BorderThickness="1"
            CornerRadius="9">
      <DockPanel LastChildFill="False">
        <TextBlock DockPanel.Dock="Left"
                   Foreground="{StaticResource MutedTextBrush}"
                   Text="{Binding FooterText}" />
        <TextBlock DockPanel.Dock="Right"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource AccentBrush}"
                   Text="VIA.WPF.Graph · Product Demo" />
      </DockPanel>
    </Border>
  </Grid>
</Window>
