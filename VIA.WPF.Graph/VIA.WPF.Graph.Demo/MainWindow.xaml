<Window x:Class="VIA.WPF.Graph.Demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:VIA.WPF.Graph.Demo.Views"
        Title="VIA.WPF.Graph – Demo"
        Width="1420"
        Height="880"
        WindowState="Maximized"
        MinWidth="1100"
        MinHeight="700"
        Background="#EEF3F8">
  <Window.Resources>
    <DropShadowEffect x:Key="SoftElevation"
                      BlurRadius="22"
                      ShadowDepth="3"
                      Opacity="0.14"
                      Color="#FF284255" />

    <Style x:Key="DemoTabControlStyle"
           TargetType="{x:Type TabControl}">
      <Setter Property="Background"
              Value="#EEF3F8" />
      <Setter Property="BorderThickness"
              Value="0" />
      <Setter Property="Padding"
              Value="16" />
    </Style>

    <Style x:Key="DemoTabItemStyle"
           TargetType="{x:Type TabItem}">
      <Setter Property="Foreground"
              Value="#FF536475" />
      <Setter Property="FontSize"
              Value="13" />
      <Setter Property="FontWeight"
              Value="SemiBold" />
      <Setter Property="Padding"
              Value="18,10" />
      <Setter Property="Margin"
              Value="0,0,8,0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type TabItem}">
            <Border x:Name="TabChrome"
                    Padding="{TemplateBinding Padding}"
                    Background="#FFE8F0F7"
                    BorderBrush="#FFD2DEE8"
                    BorderThickness="1"
                    CornerRadius="12">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                ContentSource="Header" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver"
                       Value="True">
                <Setter TargetName="TabChrome"
                        Property="Background"
                        Value="#FFF3F7FB" />
              </Trigger>
              <Trigger Property="IsSelected"
                       Value="True">
                <Setter TargetName="TabChrome"
                        Property="Background"
                        Value="#FFFFFFFF" />
                <Setter TargetName="TabChrome"
                        Property="BorderBrush"
                        Value="#FF9FB7CC" />
                <Setter Property="Foreground"
                        Value="#FF1E5A96" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid Background="#EEF3F8">
    <TabControl Style="{StaticResource DemoTabControlStyle}"
                ItemContainerStyle="{StaticResource DemoTabItemStyle}"
                SelectedIndex="0">
      <TabItem Header="UIX Demo">
        <Border Margin="0,14,0,0"
                Background="#FFF8FBFE"
                CornerRadius="18"
                Effect="{StaticResource SoftElevation}">
          <views:UIXDemoView />
        </Border>
      </TabItem>

      <TabItem Header="Technical Demo">
        <Border Margin="0,14,0,0"
                Background="#FFFFFFFF"
                CornerRadius="18"
                Effect="{StaticResource SoftElevation}">
          <views:TechnicalDemoView />
        </Border>
      </TabItem>
    </TabControl>
  </Grid>
</Window>
