<Window x:Class="VIA.WPF.Graph.Demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:graphControls="clr-namespace:VIA.WPF.Graph.Wpf.Controls;assembly=VIA.WPF.Graph.Wpf"
        Title="VIA.WPF.Graph – Phase 5 Demo Testsets"
        Width="1420"
        Height="880"
        MinWidth="1100"
        MinHeight="700">
  <Grid Margin="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="14" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <DockPanel Grid.Row="0">
      <StackPanel DockPanel.Dock="Left">
        <TextBlock FontSize="22"
                   FontWeight="SemiBold"
                   Text="Phase 5 – Demo-Testsets" />
        <TextBlock Margin="0,6,0,0"
                   Text="Small, Medium, Large, Groups und Error validieren neutrale Graphdokumente, Graphviz-Layout, WPF-Rendering und kontrollierte Fehlerfälle vor der UserFlow-Integration."
                   TextWrapping="Wrap" />
        <TextBlock Margin="0,6,0,0"
                   FontWeight="SemiBold"
                   Text="{Binding ResultText}"
                   TextWrapping="Wrap" />
      </StackPanel>
    </DockPanel>

    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="340" />
        <ColumnDefinition Width="14" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0"
              Padding="14"
              BorderBrush="#FFCBD5DF"
              BorderThickness="1"
              Background="#FFF8FAFC">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel>
            <TextBlock FontWeight="SemiBold"
                       Text="Testset" />
            <ComboBox Margin="0,6,0,12"
                      ItemsSource="{Binding TestSets}"
                      SelectedItem="{Binding SelectedTestSet, Mode=TwoWay}"
                      DisplayMemberPath="Name" />

            <TextBlock FontWeight="SemiBold"
                       Text="Layout direction" />
            <ComboBox Margin="0,6,0,12"
                      ItemsSource="{Binding LayoutDirections}"
                      SelectedItem="{Binding SelectedDirection, Mode=TwoWay}" />

            <Button Padding="12,7"
                    Command="{Binding RunLayoutCommand}"
                    Content="Layout erneut ausführen" />

            <Separator Margin="0,14,0,14" />

            <TextBlock FontWeight="SemiBold"
                       Text="Ansicht" />
            <Button Margin="0,8,0,0"
                    Padding="12,7"
                    Command="{Binding ShowAreaOverviewCommand}"
                    Content="Bereichsübersicht" />
            <Button Margin="0,8,0,0"
                    Padding="12,7"
                    Command="{Binding ShowFullGraphCommand}"
                    Content="Gesamtgraph" />

            <Separator Margin="0,14,0,14" />

            <TextBlock FontWeight="SemiBold"
                       Text="Navigation" />
            <UniformGrid Margin="0,8,0,0"
                         Columns="2">
              <Button Margin="0,0,4,0"
                      Padding="10,7"
                      Command="{Binding UseFitModeCommand}"
                      Content="Fit-Modus" />
              <Button Margin="4,0,0,0"
                      Padding="10,7"
                      Command="{Binding UseFreePanZoomModeCommand}"
                      Content="Frei bewegen" />
            </UniformGrid>
            <UniformGrid Margin="0,8,0,0"
                         Columns="3">
              <Button Margin="0,0,4,0"
                      Padding="10,7"
                      Command="{Binding FitToGraphCommand}"
                      Content="Fit" />
              <Button Margin="4,0,4,0"
                      Padding="10,7"
                      Command="{Binding SetActualSizeCommand}"
                      Content="100 %" />
              <Button Margin="4,0,0,0"
                      Padding="10,7"
                      Command="{Binding CenterGraphCommand}"
                      Content="Zentrieren" />
            </UniformGrid>
            <TextBlock Margin="0,8,0,0"
                       Text="{Binding ZoomText}"
                       FontWeight="SemiBold" />
            <TextBlock Margin="0,4,0,0"
                       Text="{Binding NavigationModeText}"
                       TextWrapping="Wrap" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="#FF52616D"
                       Text="Mausrad zoomt. Rechte oder mittlere Maustaste ziehen verschiebt den Graph."
                       TextWrapping="Wrap" />


            <Separator Margin="0,14,0,14" />

            <TextBlock FontWeight="SemiBold"
                       Text="Markierungsgruppen" />
            <ComboBox Margin="0,6,0,8"
                      ItemsSource="{Binding MarkerGroupIds}"
                      SelectedItem="{Binding SelectedMarkerGroupId, Mode=TwoWay}" />
            <UniformGrid Columns="3">
              <Button Margin="0,0,4,0"
                      Padding="10,7"
                      Command="{Binding ApplyMarkerGroupSelectionCommand}"
                      Content="Filter" />
              <Button Margin="4,0,4,0"
                      Padding="10,7"
                      Command="{Binding FocusMarkerGroupCommand}"
                      Content="Fokus" />
              <Button Margin="4,0,0,0"
                      Padding="10,7"
                      Command="{Binding ClearMarkerGroupsCommand}"
                      Content="Clear" />
            </UniformGrid>
            <TextBlock Margin="0,8,0,0"
                       Text="{Binding MarkerGroupStatusText}"
                       TextWrapping="Wrap" />
            <Separator Margin="0,14,0,14" />

            <TextBlock FontWeight="SemiBold"
                       Text="Visuelle Dichte" />
            <UniformGrid Margin="0,8,0,0"
                         Columns="2">
              <Button Margin="0,0,4,0"
                      Padding="10,7"
                      Command="{Binding SetCompactDensityCommand}"
                      Content="Kompakt" />
              <Button Margin="4,0,0,0"
                      Padding="10,7"
                      Command="{Binding SetNormalDensityCommand}"
                      Content="Normal" />
            </UniformGrid>

            <Separator Margin="0,14,0,14" />

            <TextBlock FontWeight="SemiBold"
                       Text="Beschreibung" />
            <TextBlock Margin="0,6,0,0"
                       Text="{Binding SelectedTestSet.Description}"
                       TextWrapping="Wrap" />

            <Expander Margin="0,14,0,0"
                      Header="Technische Details"
                      IsExpanded="True">
              <TextBox Margin="0,8,0,0"
                       MinHeight="260"
                       IsReadOnly="True"
                       AcceptsReturn="True"
                       Text="{Binding TechnicalDetails, Mode=OneWay}"
                       TextWrapping="NoWrap"
                       VerticalScrollBarVisibility="Auto"
                       HorizontalScrollBarVisibility="Auto"
                       FontFamily="Consolas"
                       FontSize="12"
                       Padding="10" />
            </Expander>
          </StackPanel>
        </ScrollViewer>
      </Border>

      <Border x:Name="GraphCanvasHost"
              Grid.Column="2"
              ClipToBounds="True"
              BorderBrush="#FFCBD5DF"
              BorderThickness="1"
              Background="#FFFFFFFF">
        <graphControls:GraphCanvas x:Name="GraphCanvasView"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch"
                                   Document="{Binding CurrentDocument}"
                                   LayoutResult="{Binding CurrentLayout}"
                                   ActiveViewMode="{Binding ActiveViewMode, Mode=TwoWay}"
                                   VisualDensity="{Binding VisualDensity, Mode=TwoWay}"
                                   SelectedGroupIds="{Binding SelectedGroupIds, Mode=OneWay}"
                                   IsMarkerGroupFilterEnabled="{Binding IsMarkerGroupFilterEnabled, Mode=OneWay}"
                                   FocusedGroupId="{Binding FocusedGroupId, Mode=OneWay}"
                                   Zoom="{Binding Zoom, Mode=TwoWay}"
                                   PanX="{Binding PanX, Mode=TwoWay}"
                                   PanY="{Binding PanY, Mode=TwoWay}" />
      </Border>
    </Grid>
  </Grid>
</Window>
