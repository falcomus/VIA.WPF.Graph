<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Color x:Key="ProductDemo.PageBackgroundColor">#F3F5F7</Color>
  <Color x:Key="ProductDemo.CardBackgroundColor">#FFFFFFFF</Color>
  <Color x:Key="ProductDemo.CardBorderColor">#FFD8E4EF</Color>
  <Color x:Key="ProductDemo.PanelBackgroundColor">#FFF8FAFC</Color>
  <Color x:Key="ProductDemo.MutedTextColor">#FF607386</Color>
  <Color x:Key="ProductDemo.TitleTextColor">#FF172435</Color>
  <Color x:Key="ProductDemo.AccentColor">#FF1E5A96</Color>

  <SolidColorBrush x:Key="PageBackgroundBrush"
                   Color="{StaticResource ProductDemo.PageBackgroundColor}" />
  <SolidColorBrush x:Key="CardBackgroundBrush"
                   Color="{StaticResource ProductDemo.CardBackgroundColor}" />
  <SolidColorBrush x:Key="CardBorderBrush"
                   Color="{StaticResource ProductDemo.CardBorderColor}" />
  <SolidColorBrush x:Key="PanelBackgroundBrush"
                   Color="{StaticResource ProductDemo.PanelBackgroundColor}" />
  <SolidColorBrush x:Key="MutedTextBrush"
                   Color="{StaticResource ProductDemo.MutedTextColor}" />
  <SolidColorBrush x:Key="TitleTextBrush"
                   Color="{StaticResource ProductDemo.TitleTextColor}" />
  <SolidColorBrush x:Key="AccentBrush"
                   Color="{StaticResource ProductDemo.AccentColor}" />

  <DropShadowEffect x:Key="ProductDemo.CardShadow"
                    BlurRadius="18"
                    Direction="270"
                    Opacity="0.13"
                    ShadowDepth="4"
                    Color="#FF2C4054" />

  <DropShadowEffect x:Key="ProductDemo.SelectedTreeItemShadow"
                    BlurRadius="10"
                    Direction="270"
                    Opacity="0.12"
                    ShadowDepth="2"
                    Color="#FF244662" />

  <Style x:Key="CardBorderStyle"
         TargetType="{x:Type Border}">
    <Setter Property="Background"
            Value="{StaticResource CardBackgroundBrush}" />
    <Setter Property="BorderBrush"
            Value="{StaticResource CardBorderBrush}" />
    <Setter Property="BorderThickness"
            Value="1" />
    <Setter Property="CornerRadius"
            Value="10" />
    <Setter Property="SnapsToDevicePixels"
            Value="True" />
    <Setter Property="Effect"
            Value="{StaticResource ProductDemo.CardShadow}" />
  </Style>

  <Style x:Key="InsetPanelBorderStyle"
         TargetType="{x:Type Border}">
    <Setter Property="Background"
            Value="{StaticResource PanelBackgroundBrush}" />
    <Setter Property="BorderBrush"
            Value="#FFE0E9F2" />
    <Setter Property="BorderThickness"
            Value="1" />
    <Setter Property="CornerRadius"
            Value="8" />
    <Setter Property="SnapsToDevicePixels"
            Value="True" />
  </Style>

  <Style x:Key="WorkspaceHeaderBorderStyle"
         TargetType="{x:Type Border}">
    <Setter Property="Background"
            Value="{StaticResource CardBackgroundBrush}" />
    <Setter Property="BorderBrush"
            Value="#FFE2EBF3" />
    <Setter Property="BorderThickness"
            Value="0,0,0,1" />
    <Setter Property="CornerRadius"
            Value="0" />
    <Setter Property="SnapsToDevicePixels"
            Value="True" />
  </Style>

  <Style x:Key="ToolbarButtonStyle"
         TargetType="{x:Type Button}">
    <Setter Property="MinHeight"
            Value="32" />
    <Setter Property="Padding"
            Value="12,5" />
    <Setter Property="Margin"
            Value="0,0,7,0" />
    <Setter Property="BorderThickness"
            Value="1" />
    <Setter Property="BorderBrush"
            Value="#FFC9D8E6" />
    <Setter Property="Background"
            Value="#FFFFFFFF" />
    <Setter Property="Foreground"
            Value="#FF26384A" />
    <Setter Property="FontWeight"
            Value="SemiBold" />
    <Setter Property="Cursor"
            Value="Hand" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Button}">
          <Border x:Name="ButtonChrome"
                  MinHeight="{TemplateBinding MinHeight}"
                  Padding="{TemplateBinding Padding}"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="7"
                  SnapsToDevicePixels="True">
            <ContentPresenter HorizontalAlignment="Center"
                              VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver"
                     Value="True">
              <Setter TargetName="ButtonChrome"
                      Property="Background"
                      Value="#FFF4F8FC" />
              <Setter TargetName="ButtonChrome"
                      Property="BorderBrush"
                      Value="#FF9FB7CC" />
            </Trigger>
            <Trigger Property="IsPressed"
                     Value="True">
              <Setter TargetName="ButtonChrome"
                      Property="Background"
                      Value="#FFE7F0F8" />
            </Trigger>
            <Trigger Property="IsEnabled"
                     Value="False">
              <Setter Property="Opacity"
                      Value="0.55" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="PrimaryToolbarButtonStyle"
         BasedOn="{StaticResource ToolbarButtonStyle}"
         TargetType="{x:Type Button}">
    <Setter Property="BorderBrush"
            Value="#FF1E5A96" />
    <Setter Property="Background"
            Value="#FF1E5A96" />
    <Setter Property="Foreground"
            Value="#FFFFFFFF" />
  </Style>

  <Style x:Key="MutedTextStyle"
         TargetType="{x:Type TextBlock}">
    <Setter Property="Foreground"
            Value="{StaticResource MutedTextBrush}" />
    <Setter Property="TextWrapping"
            Value="Wrap" />
  </Style>

</ResourceDictionary>
