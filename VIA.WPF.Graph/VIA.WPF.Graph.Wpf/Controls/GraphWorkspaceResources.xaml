<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:graphControls="clr-namespace:VIA.WPF.Graph.Wpf.Controls"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
  <Color x:Key="GraphWorkspace.SurfaceBackgroundColor">#FFF4F6F8</Color>
  <Color x:Key="GraphWorkspace.ToolbarBackgroundColor">#FFF8FAFC</Color>
  <Color x:Key="GraphWorkspace.BorderColor">#FFD8E4EC</Color>
  <Color x:Key="GraphWorkspace.SeparatorColor">#FFD8E2EC</Color>
  <Color x:Key="GraphWorkspace.TextColor">#FF2D3D4F</Color>
  <Color x:Key="GraphWorkspace.MutedTextColor">#FF4C5C6C</Color>
  <Color x:Key="GraphWorkspace.ButtonBackgroundColor">#FFFFFFFF</Color>
  <Color x:Key="GraphWorkspace.ButtonHoverColor">#FFF0F5FA</Color>
  <Color x:Key="GraphWorkspace.ButtonPressedColor">#FFE4EDF6</Color>
  <Color x:Key="GraphWorkspace.ScrollCornerColor">#FFE7ECF1</Color>

  <Color x:Key="GraphWorkspace.NavigationBackgroundColor">#FFF7F9FC</Color>
  <Color x:Key="GraphWorkspace.NavigationGroupBackgroundColor">#FF202123</Color>
  <Color x:Key="GraphWorkspace.NavigationGroupHoverBackgroundColor">#FF2B2C2F</Color>
  <Color x:Key="GraphWorkspace.NavigationGroupSelectedBackgroundColor">#FF3A83C4</Color>
  <Color x:Key="GraphWorkspace.NavigationGroupBorderColor">#FF3A3C40</Color>
  <Color x:Key="GraphWorkspace.NavigationGroupSelectedBorderColor">#FF174A7D</Color>
  <Color x:Key="GraphWorkspace.NavigationGroupTextColor">#FFFFFFFF</Color>
  <Color x:Key="GraphWorkspace.NavigationGroupMutedTextColor">#FFD9E9F7</Color>
  <Color x:Key="GraphWorkspace.NavigationCardBackgroundColor">#FFFFFFFF</Color>
  <Color x:Key="GraphWorkspace.NavigationCardHoverBackgroundColor">#FFF4F8FC</Color>
  <Color x:Key="GraphWorkspace.NavigationCardSelectedBackgroundColor">#FFEAF3FB</Color>
  <Color x:Key="GraphWorkspace.NavigationCardBorderColor">#FFC9D8E6</Color>
  <Color x:Key="GraphWorkspace.NavigationCardHoverBorderColor">#FF8FAEC8</Color>
  <Color x:Key="GraphWorkspace.NavigationCardSelectedBorderColor">#FF1E5A96</Color>
  <Color x:Key="GraphWorkspace.NavigationReferenceBackgroundColor">#FFFFF8E1</Color>
  <Color x:Key="GraphWorkspace.NavigationReferenceBorderColor">#FFD6B65E</Color>
  <Color x:Key="GraphWorkspace.NavigationTerminalBackgroundColor">#FFF1F5F8</Color>
  <Color x:Key="GraphWorkspace.NavigationMissingBackgroundColor">#FFFFECEF</Color>
  <Color x:Key="GraphWorkspace.NavigationMissingBorderColor">#FFD66A75</Color>
  <Color x:Key="GraphWorkspace.NavigationExpanderColor">#FF315B7E</Color>
  <Color x:Key="GraphWorkspace.NavigationShadowColor">#FF244662</Color>

  <SolidColorBrush x:Key="GraphWorkspace.SurfaceBackgroundBrush"
                   Color="{StaticResource GraphWorkspace.SurfaceBackgroundColor}" />
  <SolidColorBrush x:Key="GraphWorkspace.ToolbarBackgroundBrush"
                   Color="{StaticResource GraphWorkspace.ToolbarBackgroundColor}" />
  <SolidColorBrush x:Key="GraphWorkspace.BorderBrush"
                   Color="{StaticResource GraphWorkspace.BorderColor}" />
  <SolidColorBrush x:Key="GraphWorkspace.SeparatorBrush"
                   Color="{StaticResource GraphWorkspace.SeparatorColor}" />
  <SolidColorBrush x:Key="GraphWorkspace.TextBrush"
                   Color="{StaticResource GraphWorkspace.TextColor}" />
  <SolidColorBrush x:Key="GraphWorkspace.MutedTextBrush"
                   Color="{StaticResource GraphWorkspace.MutedTextColor}" />
  <SolidColorBrush x:Key="GraphWorkspace.ButtonBackgroundBrush"
                   Color="{StaticResource GraphWorkspace.ButtonBackgroundColor}" />
  <SolidColorBrush x:Key="GraphWorkspace.ButtonHoverBrush"
                   Color="{StaticResource GraphWorkspace.ButtonHoverColor}" />
  <SolidColorBrush x:Key="GraphWorkspace.ButtonPressedBrush"
                   Color="{StaticResource GraphWorkspace.ButtonPressedColor}" />
  <SolidColorBrush x:Key="GraphWorkspace.ScrollCornerBrush"
                   Color="{StaticResource GraphWorkspace.ScrollCornerColor}" />

  <SolidColorBrush x:Key="GraphWorkspace.NavigationBackgroundBrush"
                   Color="{StaticResource GraphWorkspace.NavigationBackgroundColor}" />
  <SolidColorBrush x:Key="GraphWorkspace.NavigationGroupBackgroundBrush"
                   Color="{StaticResource GraphWorkspace.NavigationGroupBackgroundColor}" />
  <SolidColorBrush x:Key="GraphWorkspace.NavigationGroupHoverBackgroundBrush"
                   Color="{StaticResource GraphWorkspace.NavigationGroupHoverBackgroundColor}" />
  <SolidColorBrush x:Key="GraphWorkspace.NavigationGroupSelectedBackgroundBrush"
                   Color="{StaticResource GraphWorkspace.NavigationGroupSelectedBackgroundColor}" />
  <SolidColorBrush x:Key="GraphWorkspace.NavigationGroupBorderBrush"
                   Color="{StaticResource GraphWorkspace.NavigationGroupBorderColor}" />
  <SolidColorBrush x:Key="GraphWorkspace.NavigationGroupSelectedBorderBrush"
                   Color="{StaticResource GraphWorkspace.NavigationGroupSelectedBorderColor}" />
  <SolidColorBrush x:Key="GraphWorkspace.NavigationGroupTextBrush"
                   Color="{StaticResource GraphWorkspace.NavigationGroupTextColor}" />
  <SolidColorBrush x:Key="GraphWorkspace.NavigationGroupMutedTextBrush"
                   Color="{StaticResource GraphWorkspace.NavigationGroupMutedTextColor}" />
  <SolidColorBrush x:Key="GraphWorkspace.NavigationCardBackgroundBrush"
                   Color="{StaticResource GraphWorkspace.NavigationCardBackgroundColor}" />
  <SolidColorBrush x:Key="GraphWorkspace.NavigationCardHoverBackgroundBrush"
                   Color="{StaticResource GraphWorkspace.NavigationCardHoverBackgroundColor}" />
  <SolidColorBrush x:Key="GraphWorkspace.NavigationCardSelectedBackgroundBrush"
                   Color="{StaticResource GraphWorkspace.NavigationCardSelectedBackgroundColor}" />
  <SolidColorBrush x:Key="GraphWorkspace.NavigationCardBorderBrush"
                   Color="{StaticResource GraphWorkspace.NavigationCardBorderColor}" />
  <SolidColorBrush x:Key="GraphWorkspace.NavigationCardHoverBorderBrush"
                   Color="{StaticResource GraphWorkspace.NavigationCardHoverBorderColor}" />
  <SolidColorBrush x:Key="GraphWorkspace.NavigationCardSelectedBorderBrush"
                   Color="{StaticResource GraphWorkspace.NavigationCardSelectedBorderColor}" />
  <SolidColorBrush x:Key="GraphWorkspace.NavigationReferenceBackgroundBrush"
                   Color="{StaticResource GraphWorkspace.NavigationReferenceBackgroundColor}" />
  <SolidColorBrush x:Key="GraphWorkspace.NavigationReferenceBorderBrush"
                   Color="{StaticResource GraphWorkspace.NavigationReferenceBorderColor}" />
  <SolidColorBrush x:Key="GraphWorkspace.NavigationTerminalBackgroundBrush"
                   Color="{StaticResource GraphWorkspace.NavigationTerminalBackgroundColor}" />
  <SolidColorBrush x:Key="GraphWorkspace.NavigationMissingBackgroundBrush"
                   Color="{StaticResource GraphWorkspace.NavigationMissingBackgroundColor}" />
  <SolidColorBrush x:Key="GraphWorkspace.NavigationMissingBorderBrush"
                   Color="{StaticResource GraphWorkspace.NavigationMissingBorderColor}" />
  <SolidColorBrush x:Key="GraphWorkspace.NavigationExpanderBrush"
                   Color="{StaticResource GraphWorkspace.NavigationExpanderColor}" />

  <DropShadowEffect x:Key="GraphWorkspace.NavigationSelectedShadow"
                    BlurRadius="10"
                    Direction="270"
                    Opacity="0.14"
                    ShadowDepth="2"
                    Color="{StaticResource GraphWorkspace.NavigationShadowColor}" />

  <GridLength x:Key="GraphWorkspace.NavigationTreeColumnWidth">340</GridLength>
  <GridLength x:Key="GraphWorkspace.SplitterColumnWidth">5</GridLength>
  <sys:Double x:Key="GraphWorkspace.NavigationTreeMinWidth">260</sys:Double>
  <sys:Double x:Key="GraphWorkspace.SplitterWidth">5</sys:Double>
  <sys:Double x:Key="GraphWorkspace.ScrollBarThickness">13</sys:Double>
  <sys:Double x:Key="GraphWorkspace.NavigationExpanderSize">18</sys:Double>
  <CornerRadius x:Key="GraphWorkspace.NavigationCardCornerRadius">7</CornerRadius>
  <CornerRadius x:Key="GraphWorkspace.NavigationGroupCornerRadius">8</CornerRadius>
  <sys:Double x:Key="GraphWorkspace.NavigationCardMinHeight">42</sys:Double>
  <sys:Double x:Key="GraphWorkspace.NavigationGroupMinHeight">44</sys:Double>

  <Thickness x:Key="GraphWorkspace.ToolbarPadding">10,8</Thickness>
  <Thickness x:Key="GraphWorkspace.ToolbarButtonPadding">10,4</Thickness>
  <Thickness x:Key="GraphWorkspace.ToolbarButtonMargin">0,0,6,0</Thickness>
  <Thickness x:Key="GraphWorkspace.ToolbarComboBoxMargin">4,0,8,0</Thickness>
  <Thickness x:Key="GraphWorkspace.LastToolbarComboBoxMargin">4,0,0,0</Thickness>
  <Thickness x:Key="GraphWorkspace.ScrollBarHorizontalMargin">2,0,2,2</Thickness>
  <Thickness x:Key="GraphWorkspace.ScrollBarVerticalMargin">0,2,2,2</Thickness>
  <Thickness x:Key="GraphWorkspace.ScrollCornerMargin">0,0,2,2</Thickness>
  <Thickness x:Key="GraphWorkspace.NavigationTreePadding">10,8,10,10</Thickness>
  <Thickness x:Key="GraphWorkspace.NavigationCardPadding">12,8</Thickness>
  <Thickness x:Key="GraphWorkspace.NavigationGroupPadding">12,9</Thickness>
  <Thickness x:Key="GraphWorkspace.NavigationCardMargin">0,2,4,2</Thickness>
  <Thickness x:Key="GraphWorkspace.NavigationGroupMargin">0,6,4,3</Thickness>
  <Thickness x:Key="GraphWorkspace.NavigationChildrenMargin">3,0,0,1</Thickness>
  <Thickness x:Key="GraphWorkspace.NavigationSubtitleMargin">0,3,0,0</Thickness>
  <Thickness x:Key="GraphWorkspace.NavigationExpanderMargin">0,0,4,0</Thickness>

  <StreamGeometry x:Key="GraphWorkspace.NavigationChevronGeometry">M 2,1 L 7,6 L 2,11</StreamGeometry>

  <Style x:Key="GraphWorkspace.ToolbarBorderStyle"
         TargetType="{x:Type Border}">
    <Setter Property="Padding"
            Value="{StaticResource GraphWorkspace.ToolbarPadding}" />
    <Setter Property="Background"
            Value="{StaticResource GraphWorkspace.ToolbarBackgroundBrush}" />
    <Setter Property="BorderBrush"
            Value="{StaticResource GraphWorkspace.BorderBrush}" />
    <Setter Property="BorderThickness"
            Value="0,0,0,1" />
    <Setter Property="SnapsToDevicePixels"
            Value="True" />
  </Style>

  <Style x:Key="GraphWorkspace.ToolbarButtonStyle"
         TargetType="{x:Type Button}">
    <Setter Property="MinHeight"
            Value="28" />
    <Setter Property="Padding"
            Value="{StaticResource GraphWorkspace.ToolbarButtonPadding}" />
    <Setter Property="Margin"
            Value="{StaticResource GraphWorkspace.ToolbarButtonMargin}" />
    <Setter Property="FontWeight"
            Value="SemiBold" />
    <Setter Property="Cursor"
            Value="Hand" />
    <Setter Property="Foreground"
            Value="{StaticResource GraphWorkspace.TextBrush}" />
    <Setter Property="Background"
            Value="{StaticResource GraphWorkspace.ButtonBackgroundBrush}" />
    <Setter Property="BorderBrush"
            Value="{StaticResource GraphWorkspace.BorderBrush}" />
    <Setter Property="BorderThickness"
            Value="1" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Button}">
          <Border x:Name="ButtonChrome"
                  MinHeight="{TemplateBinding MinHeight}"
                  Padding="{TemplateBinding Padding}"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="6"
                  SnapsToDevicePixels="True">
            <ContentPresenter HorizontalAlignment="Center"
                              VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver"
                     Value="True">
              <Setter TargetName="ButtonChrome"
                      Property="Background"
                      Value="{StaticResource GraphWorkspace.ButtonHoverBrush}" />
            </Trigger>
            <Trigger Property="IsPressed"
                     Value="True">
              <Setter TargetName="ButtonChrome"
                      Property="Background"
                      Value="{StaticResource GraphWorkspace.ButtonPressedBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled"
                     Value="False">
              <Setter Property="Opacity"
                      Value="0.56" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="GraphWorkspace.ToolbarLabelStyle"
         TargetType="{x:Type TextBlock}">
    <Setter Property="VerticalAlignment"
            Value="Center" />
    <Setter Property="Foreground"
            Value="{StaticResource GraphWorkspace.MutedTextBrush}" />
  </Style>

  <Style x:Key="GraphWorkspace.ToolbarSeparatorStyle"
         TargetType="{x:Type Border}">
    <Setter Property="Width"
            Value="1" />
    <Setter Property="Height"
            Value="22" />
    <Setter Property="Margin"
            Value="4,0,10,0" />
    <Setter Property="Background"
            Value="{StaticResource GraphWorkspace.SeparatorBrush}" />
  </Style>

  <Style x:Key="GraphWorkspace.ToolbarComboBoxStyle"
         TargetType="{x:Type ComboBox}">
    <Setter Property="Width"
            Value="118" />
    <Setter Property="MinHeight"
            Value="26" />
    <Setter Property="Margin"
            Value="{StaticResource GraphWorkspace.ToolbarComboBoxMargin}" />
    <Setter Property="VerticalAlignment"
            Value="Center" />
  </Style>

  <Style x:Key="GraphWorkspace.LastToolbarComboBoxStyle"
         BasedOn="{StaticResource GraphWorkspace.ToolbarComboBoxStyle}"
         TargetType="{x:Type ComboBox}">
    <Setter Property="Width"
            Value="110" />
    <Setter Property="Margin"
            Value="{StaticResource GraphWorkspace.LastToolbarComboBoxMargin}" />
  </Style>

  <Style x:Key="GraphWorkspace.NavigationExpanderStyle"
         TargetType="{x:Type ToggleButton}">
    <Setter Property="Width"
            Value="{StaticResource GraphWorkspace.NavigationExpanderSize}" />
    <Setter Property="Height"
            Value="{StaticResource GraphWorkspace.NavigationExpanderSize}" />
    <Setter Property="Margin"
            Value="{StaticResource GraphWorkspace.NavigationExpanderMargin}" />
    <Setter Property="VerticalAlignment"
            Value="Center" />
    <Setter Property="Focusable"
            Value="False" />
    <Setter Property="Background"
            Value="Transparent" />
    <Setter Property="BorderThickness"
            Value="0" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type ToggleButton}">
          <Grid Background="Transparent">
            <Path x:Name="Chevron"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Data="{StaticResource GraphWorkspace.NavigationChevronGeometry}"
                  Stroke="{StaticResource GraphWorkspace.NavigationExpanderBrush}"
                  StrokeThickness="1.8"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round">
              <Path.RenderTransform>
                <RotateTransform Angle="0"
                                 CenterX="4.5"
                                 CenterY="6" />
              </Path.RenderTransform>
            </Path>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked"
                     Value="True">
              <Setter TargetName="Chevron"
                      Property="RenderTransform">
                <Setter.Value>
                  <RotateTransform Angle="90"
                                   CenterX="4.5"
                                   CenterY="6" />
                </Setter.Value>
              </Setter>
            </Trigger>
            <Trigger Property="IsMouseOver"
                     Value="True">
              <Setter Property="Opacity"
                      Value="0.72" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="GraphWorkspace.NavigationItemCardStyle"
         TargetType="{x:Type Border}">
    <Setter Property="MinHeight"
            Value="{StaticResource GraphWorkspace.NavigationCardMinHeight}" />
    <Setter Property="Padding"
            Value="{StaticResource GraphWorkspace.NavigationCardPadding}" />
    <Setter Property="Margin"
            Value="{StaticResource GraphWorkspace.NavigationCardMargin}" />
    <Setter Property="Background"
            Value="{StaticResource GraphWorkspace.NavigationCardBackgroundBrush}" />
    <Setter Property="BorderBrush"
            Value="{StaticResource GraphWorkspace.NavigationCardBorderBrush}" />
    <Setter Property="BorderThickness"
            Value="1" />
    <Setter Property="CornerRadius"
            Value="{StaticResource GraphWorkspace.NavigationCardCornerRadius}" />
    <Setter Property="SnapsToDevicePixels"
            Value="True" />
    <Style.Triggers>
      <DataTrigger Binding="{Binding IsReference}"
                   Value="True">
        <Setter Property="Background"
                Value="{StaticResource GraphWorkspace.NavigationReferenceBackgroundBrush}" />
        <Setter Property="BorderBrush"
                Value="{StaticResource GraphWorkspace.NavigationReferenceBorderBrush}" />
      </DataTrigger>
      <DataTrigger Binding="{Binding IsTerminal}"
                   Value="True">
        <Setter Property="Background"
                Value="{StaticResource GraphWorkspace.NavigationTerminalBackgroundBrush}" />
      </DataTrigger>
      <DataTrigger Binding="{Binding IsMissingTarget}"
                   Value="True">
        <Setter Property="Background"
                Value="{StaticResource GraphWorkspace.NavigationMissingBackgroundBrush}" />
        <Setter Property="BorderBrush"
                Value="{StaticResource GraphWorkspace.NavigationMissingBorderBrush}" />
      </DataTrigger>
      <DataTrigger Binding="{Binding IsGroup}"
                   Value="True">
        <Setter Property="MinHeight"
                Value="{StaticResource GraphWorkspace.NavigationGroupMinHeight}" />
        <Setter Property="Padding"
                Value="{StaticResource GraphWorkspace.NavigationGroupPadding}" />
        <Setter Property="Margin"
                Value="{StaticResource GraphWorkspace.NavigationGroupMargin}" />
        <Setter Property="Background"
                Value="{StaticResource GraphWorkspace.NavigationGroupBackgroundBrush}" />
        <Setter Property="BorderBrush"
                Value="{StaticResource GraphWorkspace.NavigationGroupBorderBrush}" />
        <Setter Property="CornerRadius"
                Value="{StaticResource GraphWorkspace.NavigationGroupCornerRadius}" />
      </DataTrigger>
      <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType={x:Type TreeViewItem}}}"
                   Value="True">
        <Setter Property="Background"
                Value="{StaticResource GraphWorkspace.NavigationCardHoverBackgroundBrush}" />
        <Setter Property="BorderBrush"
                Value="{StaticResource GraphWorkspace.NavigationCardHoverBorderBrush}" />
      </DataTrigger>
      <MultiDataTrigger>
        <MultiDataTrigger.Conditions>
          <Condition Binding="{Binding IsGroup}"
                     Value="True" />
          <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType={x:Type TreeViewItem}}}"
                     Value="True" />
        </MultiDataTrigger.Conditions>
        <Setter Property="Background"
                Value="{StaticResource GraphWorkspace.NavigationGroupHoverBackgroundBrush}" />
        <Setter Property="BorderBrush"
                Value="{StaticResource GraphWorkspace.NavigationGroupSelectedBorderBrush}" />
      </MultiDataTrigger>
      <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType={x:Type TreeViewItem}}}"
                   Value="True">
        <Setter Property="Background"
                Value="{StaticResource GraphWorkspace.NavigationCardSelectedBackgroundBrush}" />
        <Setter Property="BorderBrush"
                Value="{StaticResource GraphWorkspace.NavigationCardSelectedBorderBrush}" />
        <Setter Property="BorderThickness"
                Value="2" />
        <Setter Property="Effect"
                Value="{StaticResource GraphWorkspace.NavigationSelectedShadow}" />
      </DataTrigger>
      <MultiDataTrigger>
        <MultiDataTrigger.Conditions>
          <Condition Binding="{Binding IsGroup}"
                     Value="True" />
          <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType={x:Type TreeViewItem}}}"
                     Value="True" />
        </MultiDataTrigger.Conditions>
        <Setter Property="Background"
                Value="{StaticResource GraphWorkspace.NavigationGroupSelectedBackgroundBrush}" />
        <Setter Property="BorderBrush"
                Value="{StaticResource GraphWorkspace.NavigationGroupSelectedBorderBrush}" />
        <Setter Property="BorderThickness"
                Value="1" />
        <Setter Property="Effect"
                Value="{x:Null}" />
      </MultiDataTrigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="GraphWorkspace.NavigationItemTitleStyle"
         TargetType="{x:Type TextBlock}">
    <Setter Property="Foreground"
            Value="{StaticResource GraphWorkspace.TextBrush}" />
    <Setter Property="FontSize"
            Value="12" />
    <Setter Property="FontWeight"
            Value="SemiBold" />
    <Setter Property="TextWrapping"
            Value="Wrap" />
    <Setter Property="TextTrimming"
            Value="None" />
    <Style.Triggers>
      <DataTrigger Binding="{Binding IsGroup}"
                   Value="True">
        <Setter Property="Foreground"
                Value="{StaticResource GraphWorkspace.NavigationGroupTextBrush}" />
        <Setter Property="FontSize"
                Value="13" />
      </DataTrigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="GraphWorkspace.NavigationItemSubtitleStyle"
         TargetType="{x:Type TextBlock}">
    <Setter Property="Margin"
            Value="{StaticResource GraphWorkspace.NavigationSubtitleMargin}" />
    <Setter Property="Foreground"
            Value="{StaticResource GraphWorkspace.MutedTextBrush}" />
    <Setter Property="FontSize"
            Value="10" />
    <Setter Property="TextWrapping"
            Value="Wrap" />
    <Setter Property="TextTrimming"
            Value="None" />
    <Style.Triggers>
      <DataTrigger Binding="{Binding Subtitle}"
                   Value="{x:Null}">
        <Setter Property="Visibility"
                Value="Collapsed" />
      </DataTrigger>
      <DataTrigger Binding="{Binding IsGroup}"
                   Value="True">
        <Setter Property="Foreground"
                Value="{StaticResource GraphWorkspace.NavigationGroupMutedTextBrush}" />
      </DataTrigger>
    </Style.Triggers>
  </Style>

  <HierarchicalDataTemplate x:Key="GraphWorkspace.NavigationItemTemplate"
                            ItemsSource="{Binding Children}">
    <Border Style="{StaticResource GraphWorkspace.NavigationItemCardStyle}">
      <StackPanel>
        <TextBlock Style="{StaticResource GraphWorkspace.NavigationItemTitleStyle}"
                   Text="{Binding Title}" />
        <TextBlock Style="{StaticResource GraphWorkspace.NavigationItemSubtitleStyle}"
                   Text="{Binding Subtitle}" />
      </StackPanel>
    </Border>
  </HierarchicalDataTemplate>


  <ItemsPanelTemplate x:Key="GraphWorkspace.NavigationItemsPanel">
    <VirtualizingStackPanel />
  </ItemsPanelTemplate>

  <Style x:Key="GraphWorkspace.NavigationTreeItemStyle"
         TargetType="{x:Type TreeViewItem}">
    <Setter Property="IsExpanded"
            Value="{Binding IsExpanded, Mode=TwoWay}" />
    <Setter Property="IsSelected"
            Value="{Binding IsSelected, Mode=TwoWay}" />
    <Setter Property="HorizontalContentAlignment"
            Value="Stretch" />
    <Setter Property="VerticalContentAlignment"
            Value="Center" />
    <Setter Property="Background"
            Value="Transparent" />
    <Setter Property="BorderThickness"
            Value="0" />
    <Setter Property="Padding"
            Value="0" />
    <Setter Property="Margin"
            Value="0" />
    <Setter Property="FocusVisualStyle"
            Value="{x:Null}" />
    <Setter Property="ItemsPanel"
            Value="{StaticResource GraphWorkspace.NavigationItemsPanel}" />
    <Setter Property="VirtualizingStackPanel.IsVirtualizing"
            Value="True" />
    <Setter Property="VirtualizingStackPanel.VirtualizationMode"
            Value="Recycling" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type TreeViewItem}">
          <Grid Background="Transparent">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ToggleButton x:Name="Expander"
                          Grid.Row="0"
                          Grid.Column="0"
                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                          Style="{StaticResource GraphWorkspace.NavigationExpanderStyle}" />

            <ContentPresenter x:Name="PART_Header"
                              Grid.Row="0"
                              Grid.Column="1"
                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                              ContentSource="Header"
                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />

            <ItemsPresenter x:Name="ItemsHost"
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="{StaticResource GraphWorkspace.NavigationChildrenMargin}" />
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="HasItems"
                     Value="False">
              <Setter TargetName="Expander"
                      Property="Visibility"
                      Value="Hidden" />
            </Trigger>
            <Trigger Property="IsExpanded"
                     Value="False">
              <Setter TargetName="ItemsHost"
                      Property="Visibility"
                      Value="Collapsed" />
            </Trigger>
            <Trigger Property="IsEnabled"
                     Value="False">
              <Setter Property="Opacity"
                      Value="0.52" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="GraphWorkspace.NavigationTreeStyle"
         TargetType="{x:Type graphControls:GraphNavigationPathTree}">
    <Setter Property="Padding"
            Value="{StaticResource GraphWorkspace.NavigationTreePadding}" />
    <Setter Property="Background"
            Value="{StaticResource GraphWorkspace.NavigationBackgroundBrush}" />
    <Setter Property="BorderThickness"
            Value="0" />
    <Setter Property="FocusVisualStyle"
            Value="{x:Null}" />
    <Setter Property="HorizontalContentAlignment"
            Value="Stretch" />
    <Setter Property="ItemTemplate"
            Value="{StaticResource GraphWorkspace.NavigationItemTemplate}" />
    <Setter Property="ItemContainerStyle"
            Value="{StaticResource GraphWorkspace.NavigationTreeItemStyle}" />
    <Setter Property="ItemsPanel"
            Value="{StaticResource GraphWorkspace.NavigationItemsPanel}" />
    <Setter Property="ScrollViewer.HorizontalScrollBarVisibility"
            Value="Auto" />
    <Setter Property="ScrollViewer.VerticalScrollBarVisibility"
            Value="Auto" />
    <Setter Property="ScrollViewer.CanContentScroll"
            Value="True" />
    <Setter Property="VirtualizingStackPanel.IsVirtualizing"
            Value="True" />
    <Setter Property="VirtualizingStackPanel.VirtualizationMode"
            Value="Recycling" />
    <Setter Property="VirtualizingPanel.ScrollUnit"
            Value="Pixel" />
  </Style>

  <Style x:Key="GraphWorkspace.SplitterStyle"
         TargetType="{x:Type GridSplitter}">
    <Setter Property="Width"
            Value="{StaticResource GraphWorkspace.SplitterWidth}" />
    <Setter Property="HorizontalAlignment"
            Value="Stretch" />
    <Setter Property="VerticalAlignment"
            Value="Stretch" />
    <Setter Property="Background"
            Value="{StaticResource GraphWorkspace.SeparatorBrush}" />
    <Setter Property="ShowsPreview"
            Value="True" />
  </Style>

  <Style x:Key="GraphWorkspace.GraphSurfaceHostStyle"
         TargetType="{x:Type Grid}">
    <Setter Property="ClipToBounds"
            Value="True" />
    <Setter Property="Background"
            Value="{StaticResource GraphWorkspace.SurfaceBackgroundBrush}" />
  </Style>

  <Style x:Key="GraphWorkspace.GraphScrollBarStyle"
         TargetType="{x:Type ScrollBar}">
    <Setter Property="Opacity"
            Value="0.82" />
    <Setter Property="Visibility"
            Value="Collapsed" />
  </Style>
</ResourceDictionary>
